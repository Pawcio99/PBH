<script>
// ═══════════════════════════════════════════
// UTILITY
// ═══════════════════════════════════════════
function resizeCanvas(canvas) {
  const ratio = window.devicePixelRatio || 1;
  const rect = canvas.parentElement.getBoundingClientRect();
  const w = Math.floor(rect.width) || 760;
  const h = parseInt(canvas.getAttribute('height')) || 200;
  canvas.width = w * ratio;
  canvas.height = h * ratio;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(ratio, ratio);
  return { ctx, w, h };
}

const GOLD = '#c9a84c';
const GOLD_DIM = '#6a5830';
const VIOLET = '#8b5cf6';
const TEAL = '#22d3ee';
const RED = '#f87171';
const AMBER = '#fb923c';
const BG2 = '#0d1526';
const TEXT_DIM = '#7a7570';

// ═══════════════════════════════════════════
// VIZ 1 — CASCADE
// ═══════════════════════════════════════════
let cascadeMode = 'bh';
let cascadeAnim = 0;

function setCascadeMode(mode) {
  cascadeMode = mode;
  document.querySelectorAll('#cascadeCanvas ~ * .viz-tab, .viz-tabs .viz-tab').forEach((t,i) => {
    if (t.closest('.viz-block') === document.getElementById('cascadeCanvas').closest('.viz-block')) {
      t.classList.toggle('active', (i === 0 && mode === 'bh') || (i === 1 && mode === 'pbh'));
    }
  });
  document.getElementById('cascadeCaption').textContent = mode === 'bh'
    ? 'BH gwiazdowa przechodzi przez kaskadę zamrożeń: Planck → Kwarki → Nukleosynteza pierwotna → Nukleosynteza gwiazdowa → BH. Każdy próg dodaje Δωzakar > 0.'
    : 'PBH nie przechodzi przez żadną kaskadę. Operator Ω̂ jest identyczny ze stanem wyjściowym epoki Plancka. Δωzakar = 0 — punkt stały funktora Φ ∘ Π.';
  cascadeAnim = 0;
}

function drawCascade() {
  const canvas = document.getElementById('cascadeCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  ctx.clearRect(0, 0, w, h);

  const isBH = cascadeMode === 'bh';
  const stages = isBH
    ? ['Planck', 'Kwarki\nQCD', 'Nukl.\npierwotna', 'Nukl.\ngwiazdowa', 'BH\ngwiazdowa']
    : ['Planck', 'BH\npierwotna'];

  const n = stages.length;
  const margin = 40;
  const usable = w - margin * 2;
  const spacing = usable / (n - 1);

  // background gradient
  const bg = ctx.createLinearGradient(0, 0, w, 0);
  bg.addColorStop(0, 'rgba(201,168,76,.03)');
  bg.addColorStop(1, isBH ? 'rgba(251,146,60,.06)' : 'rgba(139,92,246,.06)');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, w, h);

  // timeline line
  ctx.beginPath();
  ctx.moveTo(margin, h/2);
  ctx.lineTo(w - margin, h/2);
  ctx.strokeStyle = isBH ? GOLD_DIM : 'rgba(139,92,246,.4)';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([4,4]);
  ctx.stroke();
  ctx.setLineDash([]);

  // animated progress
  cascadeAnim = Math.min(cascadeAnim + 0.015, 1);
  const progressX = margin + cascadeAnim * usable;

  ctx.save();
  ctx.beginPath();
  ctx.rect(0, 0, progressX, h);
  ctx.clip();

  for (let i = 0; i < n; i++) {
    const x = margin + i * spacing;
    const isLast = i === n - 1;
    const color = isBH ? (isLast ? AMBER : GOLD) : (i === 0 ? GOLD : VIOLET);

    // connector arrow
    if (i < n - 1) {
      const x2 = margin + (i+1)*spacing;
      ctx.beginPath();
      ctx.moveTo(x + 18, h/2);
      ctx.lineTo(x2 - 18, h/2);
      ctx.strokeStyle = isBH ? 'rgba(201,168,76,.5)' : 'rgba(139,92,246,.5)';
      ctx.lineWidth = 2;
      ctx.stroke();
      // arrowhead
      ctx.beginPath();
      ctx.moveTo(x2-18, h/2-5);
      ctx.lineTo(x2-8, h/2);
      ctx.lineTo(x2-18, h/2+5);
      ctx.fillStyle = isBH ? 'rgba(201,168,76,.5)' : 'rgba(139,92,246,.5)';
      ctx.fill();

      // Δω label
      if (isBH) {
        ctx.font = '10px JetBrains Mono, monospace';
        ctx.fillStyle = GOLD_DIM;
        ctx.textAlign = 'center';
        ctx.fillText('+Δω', (x + x2) / 2, h/2 - 12);
      }
    }

    // node circle
    ctx.beginPath();
    ctx.arc(x, h/2, 14, 0, Math.PI*2);
    ctx.fillStyle = isLast ? (isBH ? 'rgba(251,146,60,.25)' : 'rgba(139,92,246,.3)') : 'rgba(201,168,76,.15)';
    ctx.fill();
    ctx.beginPath();
    ctx.arc(x, h/2, 14, 0, Math.PI*2);
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.stroke();

    // label
    const lines = stages[i].split('\n');
    ctx.font = '11px JetBrains Mono, monospace';
    ctx.fillStyle = color;
    ctx.textAlign = 'center';
    const labelY = i % 2 === 0 ? h/2 - 30 : h/2 + 38;
    lines.forEach((line, li) => {
      ctx.fillText(line, x, labelY + li * 14);
    });
  }

  ctx.restore();

  // if PBH, show "= ω₀" annotation
  if (!isBH) {
    ctx.font = '12px JetBrains Mono, monospace';
    ctx.fillStyle = VIOLET;
    ctx.textAlign = 'center';
    ctx.fillText('Δωzakar = 0', w/2, h - 20);
    ctx.font = '11px EB Garamond, serif';
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText('(Φ ∘ Π)(ω₀) = ω₀ — punkt stały', w/2, h - 6);
  }

  if (cascadeAnim < 1) requestAnimationFrame(drawCascade);
}

// ═══════════════════════════════════════════
// VIZ 2 — FUNCTOR
// ═══════════════════════════════════════════
let functorAngle = 0;

function drawFunctor() {
  const canvas = document.getElementById('functorCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  ctx.clearRect(0, 0, w, h);
  functorAngle += 0.005;

  const cx1 = w * 0.28, cy = h / 2;
  const cx2 = w * 0.72;
  const r = Math.min(w * 0.14, 60);

  // draw Φ ∘ Π for BH (left, open spiral)
  ctx.save();
  ctx.translate(cx1, cy);
  // spiral — open loop
  ctx.beginPath();
  for (let a = 0; a < Math.PI * 3.2; a += 0.05) {
    const rad = r * 0.35 + a * 4.5;
    const x2 = Math.cos(a + functorAngle) * rad;
    const y2 = Math.sin(a + functorAngle) * rad;
    a === 0 ? ctx.moveTo(x2, y2) : ctx.lineTo(x2, y2);
  }
  ctx.strokeStyle = GOLD;
  ctx.lineWidth = 1.5;
  ctx.globalAlpha = 0.7;
  ctx.stroke();
  ctx.globalAlpha = 1;
  // label
  ctx.font = 'bold 12px JetBrains Mono, monospace';
  ctx.fillStyle = GOLD;
  ctx.textAlign = 'center';
  ctx.fillText('BH Gwiazdowa', 0, r + 22);
  ctx.font = '10px JetBrains Mono, monospace';
  ctx.fillStyle = TEXT_DIM;
  ctx.fillText('Δωzakar > 0', 0, r + 36);
  ctx.fillText('pętla otwarta', 0, r + 48);
  ctx.restore();

  // PBH (right, closed circle)
  ctx.save();
  ctx.translate(cx2, cy);
  // spinning closed loop
  ctx.beginPath();
  ctx.arc(0, 0, r * 0.7, 0, Math.PI * 2);
  ctx.strokeStyle = VIOLET;
  ctx.lineWidth = 2;
  ctx.globalAlpha = 0.85;
  ctx.stroke();
  ctx.globalAlpha = 1;
  // spinning dot on circle
  const dotX = Math.cos(functorAngle * 2) * r * 0.7;
  const dotY = Math.sin(functorAngle * 2) * r * 0.7;
  ctx.beginPath();
  ctx.arc(dotX, dotY, 5, 0, Math.PI * 2);
  ctx.fillStyle = VIOLET;
  ctx.fill();
  // arrow indicating closure
  ctx.font = '18px serif';
  ctx.fillStyle = VIOLET;
  ctx.textAlign = 'center';
  ctx.fillText('↺', 0, 7);
  // label
  ctx.font = 'bold 12px JetBrains Mono, monospace';
  ctx.fillStyle = VIOLET;
  ctx.textAlign = 'center';
  ctx.fillText('PBH', 0, r * 0.7 + 22);
  ctx.font = '10px JetBrains Mono, monospace';
  ctx.fillStyle = TEXT_DIM;
  ctx.fillText('Δωzakar = 0', 0, r * 0.7 + 36);
  ctx.fillText('punkt stały', 0, r * 0.7 + 48);
  ctx.restore();

  // middle arrow + equation
  ctx.font = '13px JetBrains Mono, monospace';
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'center';
  ctx.fillText('vs', w/2, cy);
  ctx.font = '11px JetBrains Mono, monospace';
  ctx.fillStyle = VIOLET;
  ctx.fillText('(Φ∘Π)(ω₀) = ω₀', w/2, cy + 55);

  requestAnimationFrame(drawFunctor);
}

// ═══════════════════════════════════════════
// VIZ 3 — METALLICITY
// ═══════════════════════════════════════════
let metMode = 'scatter';
let genCount = 3;

function setMetMode(mode) {
  metMode = mode;
  document.querySelectorAll('#metalCanvas').forEach(c => {
    c.closest('.viz-block').querySelectorAll('.viz-tab').forEach((t,i) => {
      t.classList.toggle('active', (i===0 && mode==='scatter') || (i===1 && mode==='accum'));
    });
  });
  drawMetal();
}

function updateGen(v) {
  genCount = parseInt(v);
  document.getElementById('genVal').textContent = v;
  drawMetal();
}

function drawMetal() {
  const canvas = document.getElementById('metalCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  ctx.clearRect(0, 0, w, h);

  const mx = 55, my = 20, mw = w - mx - 20, mh = h - my - 40;

  if (metMode === 'scatter') {
    // axes
    ctx.strokeStyle = 'rgba(255,255,255,.15)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(mx, my); ctx.lineTo(mx, my+mh); ctx.lineTo(mx+mw, my+mh); ctx.stroke();

    // axis labels
    ctx.font = '10px JetBrains Mono, monospace';
    ctx.fillStyle = TEXT_DIM;
    ctx.textAlign = 'center';
    ctx.fillText('log(M_BH / M☉)', mx + mw/2, my + mh + 30);
    ctx.save(); ctx.translate(14, my + mh/2); ctx.rotate(-Math.PI/2);
    ctx.fillText('Metaliczność Z / Z☉', 0, 0); ctx.restore();

    // grid
    [0, .25, .5, .75, 1].forEach(t => {
      const y = my + mh - t * mh;
      ctx.beginPath(); ctx.moveTo(mx, y); ctx.lineTo(mx+mw, y);
      ctx.strokeStyle = 'rgba(255,255,255,.05)'; ctx.lineWidth = 1; ctx.stroke();
      ctx.fillStyle = TEXT_DIM; ctx.font = '9px JetBrains Mono, monospace';
      ctx.textAlign = 'right';
      ctx.fillText((t * 1.2).toFixed(1), mx - 6, y + 3);
    });
    [5,6,7,8,9].forEach((v, i) => {
      const x = mx + (i/4) * mw;
      ctx.fillStyle = TEXT_DIM; ctx.font = '9px JetBrains Mono, monospace';
      ctx.textAlign = 'center';
      ctx.fillText('10^'+v, x, my + mh + 14);
    });

    // BH gwiazdowe — positive correlation
    const seed = 42;
    function rnd(s) { let x = Math.sin(s) * 10000; return x - Math.floor(x); }
    for (let i = 0; i < 25; i++) {
      const logM = 5 + rnd(i*7+seed) * 4.5;
      const Z = 0.2 + logM/9 * 0.7 + (rnd(i*3+1) - 0.5) * 0.15;
      const x = mx + ((logM - 5)/4) * mw;
      const y = my + mh - Math.min(Z, 1.1) / 1.2 * mh;
      ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(201,168,76,.75)'; ctx.fill();
    }
    // trend line BH
    ctx.beginPath(); ctx.moveTo(mx, my + mh * 0.85); ctx.lineTo(mx + mw, my + mh * 0.1);
    ctx.strokeStyle = 'rgba(201,168,76,.35)'; ctx.lineWidth = 1.5; ctx.setLineDash([5,4]); ctx.stroke();
    ctx.setLineDash([]);

    // PBH — flat near zero
    for (let i = 0; i < 15; i++) {
      const logM = 5 + rnd(i*11+200) * 4.5;
      const Z = 0.005 + rnd(i*5+300) * 0.018;
      const x = mx + ((logM - 5)/4) * mw;
      const y = my + mh - (Z / 1.2) * mh;
      ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(139,92,246,.75)'; ctx.fill();
    }

    // Abell 2744-QSO1 — anomaly
    const ax = mx + ((7.7-5)/4) * mw;
    const ay = my + mh - (0.01/1.2) * mh;
    ctx.strokeStyle = RED; ctx.lineWidth = 2.5;
    ctx.beginPath(); ctx.moveTo(ax-7,ay-7); ctx.lineTo(ax+7,ay+7); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(ax+7,ay-7); ctx.lineTo(ax-7,ay+7); ctx.stroke();
    ctx.font = '10px JetBrains Mono, monospace'; ctx.fillStyle = RED;
    ctx.textAlign = 'left'; ctx.fillText('Abell 2744-QSO1', ax+10, ay+4);

    // legend
    ctx.font = '10px JetBrains Mono, monospace';
    [[GOLD,'BH gwiazdowe','circle'],[VIOLET,'PBH','circle'],[RED,'JWST anomalia','cross']].forEach(([c,l,t],i) => {
      const lx = mx + 8, ly = my + 12 + i*16;
      if (t === 'circle') { ctx.beginPath(); ctx.arc(lx+5,ly,4,0,Math.PI*2); ctx.fillStyle=c; ctx.fill(); }
      else { ctx.strokeStyle=c; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(lx,ly-4); ctx.lineTo(lx+10,ly+4); ctx.stroke(); ctx.beginPath(); ctx.moveTo(lx+10,ly-4); ctx.lineTo(lx,ly+4); ctx.stroke(); }
      ctx.fillStyle=TEXT_DIM; ctx.textAlign='left'; ctx.fillText(l, lx+14, ly+4);
    });

  } else {
    // accumulation mode
    const stages = ['Planck','Kwarki','Nukl. P','Nukl. G.' , 'BH',''];
    const n = Math.min(genCount + 2, 5);
    const bw = mw / 6;

    ctx.strokeStyle = 'rgba(255,255,255,.15)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(mx, my); ctx.lineTo(mx, my+mh); ctx.lineTo(mx+mw, my+mh); ctx.stroke();

    for (let i = 0; i < 5; i++) {
      const barH = i < n ? (i+1)/5 * mh : 0;
      const x = mx + i * (mw/5) + bw*0.1;
      const w2 = bw * 0.8;
      const active = i < n;
      const grad = ctx.createLinearGradient(0, my+mh-barH, 0, my+mh);
      grad.addColorStop(0, active ? 'rgba(201,168,76,.8)' : 'rgba(100,100,100,.2)');
      grad.addColorStop(1, active ? 'rgba(201,168,76,.15)' : 'rgba(60,60,60,.1)');
      ctx.fillStyle = grad;
      ctx.fillRect(x, my+mh-barH, w2, barH);

      ctx.font = '9px JetBrains Mono, monospace';
      ctx.fillStyle = active ? GOLD : TEXT_DIM;
      ctx.textAlign = 'center';
      ctx.fillText(stages[i], x + w2/2, my+mh+14);
      if (active && i > 0) {
        ctx.fillStyle = GOLD; ctx.font = '10px JetBrains Mono, monospace';
        ctx.fillText('+Δω', x + w2/2, my+mh-barH-6);
      }
    }

    // PBH flat line
    ctx.beginPath(); ctx.moveTo(mx, my+mh-2); ctx.lineTo(mx+mw, my+mh-2);
    ctx.strokeStyle = VIOLET; ctx.lineWidth = 2; ctx.setLineDash([6,3]); ctx.stroke();
    ctx.setLineDash([]);
    ctx.font = '10px JetBrains Mono, monospace'; ctx.fillStyle = VIOLET;
    ctx.textAlign = 'right';
    ctx.fillText('PBH: Δωzakar = 0', mx+mw, my+mh-8);
  }
}

// ═══════════════════════════════════════════
// VIZ 4 — MASS SPECTRUM
// ═══════════════════════════════════════════
function drawMass() {
  const canvas = document.getElementById('massCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  ctx.clearRect(0, 0, w, h);

  const mx = 60, my = 20, mw = w-mx-20, mh = h-my-40;
  const logMin = -1.5, logMax = 3;
  const range = logMax - logMin;

  // background
  const bg = ctx.createLinearGradient(0, my, 0, my+mh);
  bg.addColorStop(0, 'rgba(201,168,76,.03)');
  bg.addColorStop(1, 'transparent');
  ctx.fillStyle = bg; ctx.fillRect(mx, my, mw, mh);

  // axes
  ctx.strokeStyle = 'rgba(255,255,255,.15)'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(mx,my); ctx.lineTo(mx,my+mh); ctx.lineTo(mx+mw,my+mh); ctx.stroke();

  // x axis ticks
  [-1,0,1,2,3].forEach(v => {
    const x = mx + ((v - logMin)/range)*mw;
    ctx.fillStyle = TEXT_DIM; ctx.font='9px JetBrains Mono,monospace'; ctx.textAlign='center';
    ctx.fillText('10^'+v+' M☉', x, my+mh+14);
    ctx.beginPath(); ctx.moveTo(x,my+mh); ctx.lineTo(x,my+mh+4); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x,my); ctx.lineTo(x,my+mh); ctx.strokeStyle='rgba(255,255,255,.04)'; ctx.stroke();
    ctx.strokeStyle='rgba(255,255,255,.15)';
  });

  ctx.fillStyle=TEXT_DIM; ctx.font='10px JetBrains Mono,monospace'; ctx.textAlign='center';
  ctx.fillText('Masa kompaktu', mx+mw/2, my+mh+30);

  // Chandrasekhar line
  const chX = mx + ((Math.log10(1.4) - logMin)/range)*mw;
  ctx.beginPath(); ctx.moveTo(chX, my); ctx.lineTo(chX, my+mh);
  ctx.strokeStyle = 'rgba(251,146,60,.6)'; ctx.lineWidth=2; ctx.setLineDash([6,4]); ctx.stroke();
  ctx.setLineDash([]);
  ctx.font='10px JetBrains Mono,monospace'; ctx.fillStyle=AMBER; ctx.textAlign='left';
  ctx.fillText('M_Ch = 1.4 M☉', chX+6, my+14);

  // PBH band (sub-Chandrasekhar)
  const pbhFill = ctx.createLinearGradient(mx, 0, chX, 0);
  pbhFill.addColorStop(0,'rgba(139,92,246,.05)');
  pbhFill.addColorStop(1,'rgba(139,92,246,.12)');
  ctx.fillStyle=pbhFill; ctx.fillRect(mx, my, chX-mx, mh);

  // LIGO masses: 0.10–0.87 M☉
  [0.10,0.14,0.19,0.26,0.38,0.52,0.63,0.71,0.87].forEach(m => {
    const x = mx + ((Math.log10(m)-logMin)/range)*mw;
    const y = my + mh * 0.5 + (Math.random()*0.1-0.05)*mh;
    ctx.beginPath(); ctx.arc(x, my+mh*0.45, 6, 0, Math.PI*2);
    ctx.fillStyle='rgba(139,92,246,.8)'; ctx.fill();
    ctx.beginPath(); ctx.arc(x, my+mh*0.45, 6, 0, Math.PI*2);
    ctx.strokeStyle=VIOLET; ctx.lineWidth=1.5; ctx.stroke();
  });

  // BH stellar
  [1.5,2.0,3.4,7.8,15,40,85].forEach(m => {
    const x = mx + ((Math.log10(m)-logMin)/range)*mw;
    ctx.beginPath(); ctx.arc(x, my+mh*0.45, 7, 0, Math.PI*2);
    ctx.fillStyle='rgba(201,168,76,.8)'; ctx.fill();
    ctx.strokeStyle=GOLD; ctx.lineWidth=1.5; ctx.stroke();
  });

  // labels
  ctx.font='10px JetBrains Mono,monospace';
  ctx.fillStyle=VIOLET; ctx.textAlign='center';
  ctx.fillText('LIGO S251112cm · PBH', (mx + chX)/2, my+mh*0.72);
  ctx.fillText('0.10 – 0.87 M☉', (mx + chX)/2, my+mh*0.84);
  ctx.fillStyle=GOLD; ctx.textAlign='center';
  ctx.fillText('BH gwiazdowe', chX + (mx+mw-chX)/2, my+mh*0.72);

  // legend
  [[GOLD,'BH gwiazdowe'],[VIOLET,'PBH (sub-Ch.)'],[AMBER,'M_Ch granica']].forEach(([c,l],i)=>{
    const lx=mx+8, ly=my+12+i*16;
    ctx.beginPath(); ctx.arc(lx+5,ly,4,0,Math.PI*2); ctx.fillStyle=c; ctx.fill();
    ctx.fillStyle=TEXT_DIM; ctx.font='9px JetBrains Mono,monospace'; ctx.textAlign='left';
    ctx.fillText(l, lx+13, ly+4);
  });
}

// ═══════════════════════════════════════════
// VIZ 5 — COSMIC NETWORK
// ═══════════════════════════════════════════
let netTime = 0;
const netNodes = [];

function initNet(w, h) {
  netNodes.length = 0;
  // PBH nodes (gold, delta-omega=0)
  for (let i = 0; i < 12; i++) {
    netNodes.push({
      x: 40 + Math.random()*(w-80),
      y: 30 + Math.random()*(h-60),
      isPBH: true,
      vx: (Math.random()-.5)*0.2,
      vy: (Math.random()-.5)*0.2
    });
  }
  // Stellar BH (amber/dim)
  for (let i = 0; i < 20; i++) {
    netNodes.push({
      x: 40 + Math.random()*(w-80),
      y: 30 + Math.random()*(h-60),
      isPBH: false,
      metal: 0.1 + Math.random()*0.8,
      vx: (Math.random()-.5)*0.15,
      vy: (Math.random()-.5)*0.15
    });
  }
}

function drawNet() {
  const canvas = document.getElementById('netCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  netTime += 0.008;

  if (netNodes.length === 0) initNet(w, h);

  ctx.clearRect(0, 0, w, h);

  // background glow — zakar gradient
  const grd = ctx.createRadialGradient(w*0.6, h*0.4, 10, w*0.6, h*0.4, w*0.7);
  grd.addColorStop(0, 'rgba(201,168,76,.06)');
  grd.addColorStop(1, 'transparent');
  ctx.fillStyle = grd; ctx.fillRect(0,0,w,h);

  // move nodes
  netNodes.forEach(n => {
    n.x += n.vx + Math.sin(netTime + n.y*.01) * 0.1;
    n.y += n.vy + Math.cos(netTime + n.x*.01) * 0.1;
    if (n.x < 30) n.vx = Math.abs(n.vx);
    if (n.x > w-30) n.vx = -Math.abs(n.vx);
    if (n.y < 20) n.vy = Math.abs(n.vy);
    if (n.y > h-20) n.vy = -Math.abs(n.vy);
  });

  // connections: PBH to nearby stellar BH
  netNodes.filter(n=>n.isPBH).forEach(p => {
    netNodes.filter(n=>!n.isPBH).forEach(s => {
      const d = Math.hypot(p.x-s.x, p.y-s.y);
      if (d < 120) {
        ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(s.x,s.y);
        ctx.strokeStyle = `rgba(201,168,76,${(1-d/120)*.18})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    });
  });

  // draw stellar BH
  netNodes.filter(n=>!n.isPBH).forEach(n => {
    const a = 0.3 + n.metal * 0.5;
    ctx.beginPath(); ctx.arc(n.x, n.y, 4, 0, Math.PI*2);
    ctx.fillStyle = `rgba(251,146,60,${a})`; ctx.fill();
  });

  // draw PBH nodes with pulse
  netNodes.filter(n=>n.isPBH).forEach((n,i) => {
    const pulse = Math.sin(netTime * 1.5 + i * 0.8) * 3;
    // glow
    const g = ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,14+pulse);
    g.addColorStop(0,'rgba(201,168,76,.35)');
    g.addColorStop(1,'transparent');
    ctx.fillStyle=g; ctx.beginPath(); ctx.arc(n.x,n.y,14+pulse,0,Math.PI*2); ctx.fill();
    // core
    ctx.beginPath(); ctx.arc(n.x,n.y,5,0,Math.PI*2);
    ctx.fillStyle=GOLD; ctx.fill();
    ctx.beginPath(); ctx.arc(n.x,n.y,5,0,Math.PI*2);
    ctx.strokeStyle='rgba(201,168,76,.6)'; ctx.lineWidth=1.5; ctx.stroke();
  });

  // legend
  ctx.font='9px JetBrains Mono,monospace';
  [[GOLD,'PBH · Δωzakar = 0'],[AMBER,'BH gwiazdowe · Δω > 0']].forEach(([c,l],i)=>{
    ctx.beginPath(); ctx.arc(14,14+i*16,4,0,Math.PI*2); ctx.fillStyle=c; ctx.fill();
    ctx.fillStyle=TEXT_DIM; ctx.textAlign='left'; ctx.fillText(l, 24, 18+i*16);
  });

  requestAnimationFrame(drawNet);
}

// ═══════════════════════════════════════════
// VIZ 6 — PREDICTION
// ═══════════════════════════════════════════
let predMode = 'scatter';

function setPredMode(mode) {
  predMode = mode;
  document.querySelectorAll('#predCanvas').forEach(c => {
    c.closest('.viz-block').querySelectorAll('.viz-tab').forEach((t,i) => {
      t.classList.toggle('active', (i===0 && mode==='scatter') || (i===1 && mode==='hist'));
    });
  });
  drawPred();
}

function drawPred() {
  const canvas = document.getElementById('predCanvas');
  const { ctx, w, h } = resizeCanvas(canvas);
  ctx.clearRect(0, 0, w, h);

  const mx=60, my=20, mw=w-mx-20, mh=h-my-45;
  const logMin=5, logMax=10, range=logMax-logMin;

  if (predMode === 'scatter') {
    // axes
    ctx.strokeStyle='rgba(255,255,255,.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(mx,my); ctx.lineTo(mx,my+mh); ctx.lineTo(mx+mw,my+mh); ctx.stroke();
    ctx.fillStyle=TEXT_DIM; ctx.font='10px JetBrains Mono,monospace'; ctx.textAlign='center';
    ctx.fillText('log(M_BH / M☉)', mx+mw/2, my+mh+32);
    ctx.save(); ctx.translate(14, my+mh/2); ctx.rotate(-Math.PI/2);
    ctx.fillText('Metaliczność Z / Z☉', 0, 0); ctx.restore();

    // grid
    [0,.2,.4,.6,.8,1].forEach(t=>{
      const y=my+mh-t*mh;
      ctx.beginPath(); ctx.moveTo(mx,y); ctx.lineTo(mx+mw,y);
      ctx.strokeStyle='rgba(255,255,255,.04)'; ctx.lineWidth=1; ctx.stroke();
      ctx.fillStyle=TEXT_DIM; ctx.font='9px JetBrains Mono,monospace'; ctx.textAlign='right';
      ctx.fillText((t*1.2).toFixed(2), mx-5, y+3);
    });
    [5,6,7,8,9,10].forEach(v=>{
      const x=mx+((v-logMin)/range)*mw;
      ctx.fillStyle=TEXT_DIM; ctx.font='9px JetBrains Mono,monospace'; ctx.textAlign='center';
      ctx.fillText('10^'+v, x, my+mh+14);
    });

    // Regime boundary line
    const boundX = mx + ((7.5-logMin)/range)*mw;
    ctx.beginPath(); ctx.moveTo(boundX,my); ctx.lineTo(boundX,my+mh);
    ctx.strokeStyle='rgba(34,211,238,.4)'; ctx.lineWidth=1.5; ctx.setLineDash([5,3]); ctx.stroke();
    ctx.setLineDash([]);
    ctx.font='9px JetBrains Mono,monospace'; ctx.fillStyle=TEAL; ctx.textAlign='center';
    ctx.fillText('Granica reżimów', boundX, my+8);

    // Regime labels
    ctx.font='10px JetBrains Mono,monospace';
    ctx.fillStyle='rgba(201,168,76,.5)'; ctx.textAlign='center';
    ctx.fillText('Reżim I · BH gwiazdowe', mx+(boundX-mx)/2, my+mh-12);
    ctx.fillText('Z ∝ M^α (α > 0)', mx+(boundX-mx)/2, my+mh-26);
    ctx.fillStyle='rgba(139,92,246,.5)'; ctx.textAlign='center';
    ctx.fillText('Reżim II · PBH', boundX+(mx+mw-boundX)/2, my+mh-12);
    ctx.fillText('Z ≈ 0, niezal. od M', boundX+(mx+mw-boundX)/2, my+mh-26);

    // stellar BH points (Regime I)
    function rnd2(s){let x=Math.sin(s)*9999;return x-Math.floor(x);}
    for(let i=0;i<30;i++){
      const logM=5.2+rnd2(i*7+10)*2;
      const Z=0.15+(logM-5)/5*0.7+(rnd2(i*3+20)-.5)*.12;
      const x=mx+((logM-logMin)/range)*mw;
      const y=my+mh-(Math.min(Z,1.15)/1.2)*mh;
      ctx.beginPath(); ctx.arc(x,y,5,0,Math.PI*2);
      ctx.fillStyle='rgba(201,168,76,.7)'; ctx.fill();
    }

    // PBH points (Regime II) — flat
    for(let i=0;i<20;i++){
      const logM=7.6+rnd2(i*11+100)*2.2;
      const Z=0.003+rnd2(i*5+200)*0.01;
      const x=mx+((logM-logMin)/range)*mw;
      const y=my+mh-(Z/1.2)*mh;
      ctx.beginPath(); ctx.arc(x,y,5,0,Math.PI*2);
      ctx.fillStyle='rgba(139,92,246,.7)'; ctx.fill();
    }

    // Abell 2744-QSO1
    const ax=mx+((7.7-logMin)/range)*mw;
    const ay=my+mh-(0.01/1.2)*mh;
    ctx.strokeStyle=RED; ctx.lineWidth=2.5;
    [[-1,-1],[1,1],[-1,1],[1,-1]].forEach(([dx,dy])=>{
      ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(ax+dx*7,ay+dy*7); ctx.stroke();
    });
    ctx.font='10px JetBrains Mono,monospace'; ctx.fillStyle=RED; ctx.textAlign='left';
    ctx.fillText('Abell 2744-QSO1 (JWST)', ax+10, ay+4);

    // trend lines
    ctx.beginPath(); ctx.moveTo(mx, my+mh*0.88); ctx.lineTo(boundX, my+mh*0.22);
    ctx.strokeStyle='rgba(201,168,76,.3)'; ctx.lineWidth=1.5; ctx.setLineDash([4,4]); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(boundX, my+mh*0.97); ctx.lineTo(mx+mw, my+mh*0.96);
    ctx.strokeStyle='rgba(139,92,246,.3)'; ctx.stroke();
    ctx.setLineDash([]);

  } else {
    // Histogram of Z
    ctx.strokeStyle='rgba(255,255,255,.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(mx,my); ctx.lineTo(mx,my+mh); ctx.lineTo(mx+mw,my+mh); ctx.stroke();
    ctx.fillStyle=TEXT_DIM; ctx.font='10px JetBrains Mono,monospace'; ctx.textAlign='center';
    ctx.fillText('Metaliczność Z / Z☉', mx+mw/2, my+mh+32);
    ctx.save(); ctx.translate(14,my+mh/2); ctx.rotate(-Math.PI/2);
    ctx.fillText('Liczba obiektów (N)', 0, 0); ctx.restore();

    // PBH peak at Z~0
    const bw = mw/20;
    // stellar BH distribution — broad, centered ~0.5
    for(let i=0;i<20;i++){
      const x = mx + i*(mw/20);
      const Z = (i+.5)/20;
      const gauss = Math.exp(-(Z-.5)**2/(2*0.18**2));
      const H = gauss * mh * 0.7;
      const grad2 = ctx.createLinearGradient(0,my+mh-H,0,my+mh);
      grad2.addColorStop(0,'rgba(201,168,76,.7)'); grad2.addColorStop(1,'rgba(201,168,76,.1)');
      ctx.fillStyle=grad2; ctx.fillRect(x,my+mh-H,bw-2,H);
    }
    // PBH peak at Z~0
    for(let i=0;i<2;i++){
      const H = mh*(i===0?.9:.5);
      const grad2 = ctx.createLinearGradient(0,my+mh-H,0,my+mh);
      grad2.addColorStop(0,'rgba(139,92,246,.85)'); grad2.addColorStop(1,'rgba(139,92,246,.1)');
      ctx.fillStyle=grad2; ctx.fillRect(mx+i*bw,my+mh-H,bw-2,H);
    }

    // labels
    ctx.font='10px JetBrains Mono,monospace';
    ctx.fillStyle=VIOLET; ctx.textAlign='left'; ctx.fillText('PBH', mx+4, my+20);
    ctx.fillStyle=GOLD; ctx.textAlign='center'; ctx.fillText('BH gwiazdowe', mx+mw*0.6, my+20);
    ctx.fillStyle=TEXT_DIM; ctx.font='9px JetBrains Mono,monospace';
    ctx.textAlign='center'; ctx.fillText('Rozkład dwumodalny · Predykcja 7 TERJ', mx+mw/2, my+mh+44);
  }
}

// ═══════════════════════════════════════════
// INIT & RESIZE
// ═══════════════════════════════════════════
function initAll() {
  drawCascade();
  drawFunctor();
  drawMetal();
  drawMass();
  initNet(760,240);
  drawNet();
  drawPred();
}

window.addEventListener('load', () => {
  setTimeout(initAll, 100);
});
window.addEventListener('resize', () => {
  drawMetal();
  drawMass();
  drawPred();
});

// Tab helpers
document.querySelectorAll('.viz-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    this.closest('.viz-tabs').querySelectorAll('.viz-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
  });
});
